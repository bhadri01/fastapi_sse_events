# FastAPI SSE Events - Environment Configuration
#
# Copy this file to .env and customize for your environment.
# These variables will be automatically loaded by RealtimeConfig when using pydantic-settings.

# Redis Configuration
# Connection URL for Redis server
SSE_REDIS_URL=redis://localhost:6379/0

# SSE Configuration
# Heartbeat interval in seconds (5-60)
SSE_HEARTBEAT_SECONDS=15

# HTTP path where SSE endpoint will be mounted
SSE_SSE_PATH=/events

# Optional topic prefix for multi-tenancy or namespacing
SSE_TOPIC_PREFIX=

# Example Production Settings:
# SSE_REDIS_URL=redis://:password@redis-prod.example.com:6379/0
# SSE_HEARTBEAT_SECONDS=30
# SSE_SSE_PATH=/realtime
# SSE_TOPIC_PREFIX=prod
